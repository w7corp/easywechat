{
  "name": "w7corp/easywechat",
  "description": "微信SDK",
  "keywords": [
    "easywechat",
    "wechat",
    "weixin",
    "weixin-sdk",
    "sdk"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "overtrue",
      "email": "anzhengchao@gmail.com"
    }
  ],
  "require": {
    "php": ">=8.4",
    "ext-fileinfo": "*",
    "ext-openssl": "*",
    "ext-simplexml": "*",
    "ext-libxml": "*",
    "ext-curl": "*",
    "nyholm/psr7": "^1.8.2",
    "nyholm/psr7-server": "^1.1",
    "overtrue/socialite": "^4.14",
    "psr/simple-cache": "^3.0",
    "psr/http-client": "^1.0",
    "symfony/cache": "^8.0",
    "symfony/http-foundation": "^8.0",
    "symfony/psr-http-message-bridge": "^8.0",
    "symfony/http-client": "^8.0",
    "symfony/mime": "^8.0",
    "thenorthmemory/xml": "^1.1"
  },
  "require-dev": {
    "mikey179/vfsstream": "^1.6.12",
    "mockery/mockery": "^1.6.12",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^12.5",
    "symfony/var-dumper": "^8.0",
    "jetbrains/phpstorm-attributes": "^1.2",
    "laravel/pint": "^1.29"
  },
  "autoload": {
    "psr-4": {
      "EasyWeChat\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "EasyWeChat\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-merge": "composer install",
    "phpstan": "phpstan analyse --memory-limit=-1",
    "check-style": "vendor/bin/pint --test",
    "fix-style": "vendor/bin/pint",
    "test": "phpunit --colors"
  },
  "conflict": {
    "overtrue/wechat": "*"
  },
  "config": {
    "allow-plugins": {
      "php-http/discovery": true
    }
  }
}
